# Copy to .env.local or export these variables before running docker compose.
# Do not commit real keys.

CHATGPT2API_BASE_URL=http://host.docker.internal:8010
CHATGPT2API_MODEL=auto
CHATGPT2API_AUTH_KEY=

CHATGPT2API_CLASSIFY_CONCURRENCY=2
CHATGPT2API_CLASSIFY_BATCH_SIZE=25
CHATGPT_REFRESH_CLASSIFY_JOB_LIMIT=50
CHATGPT_REFRESH_EXTRACT_JOB_LIMIT=4
CHATGPT_REFRESH_VERIFY_JOB_LIMIT=2
OUTBREAK_REFRESH_INTERVAL_MS=600000

# Optional when running the Docker image as a remote D1 production worker.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CHATGPT_D1_DATABASE=epidemic-monitor
